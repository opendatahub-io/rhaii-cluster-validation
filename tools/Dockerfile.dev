ARG BUILDER_IMAGE=nvcr.io/nvidia/cuda:13.0.0-devel-ubi9
ARG RUNTIME_IMAGE=registry.access.redhat.com/ubi9/ubi:latest

# ============================================================================
# Builder Stage: Build perftest from source (needs CUDA headers)
# ============================================================================
FROM ${BUILDER_IMAGE} AS builder

# Install build dependencies (autotools needed — building from git source)
RUN dnf install -y \
    gcc gcc-c++ make diffutils \
    autoconf automake libtool \
    pciutils-devel \
    rdma-core-devel libibverbs-devel librdmacm-devel libibumad-devel \
    && dnf clean all

# Build perftest from source (git submodule) with CUDA support
COPY tools/perftest/ /tmp/perftest/
RUN test -f /tmp/perftest/autogen.sh || \
    { echo "ERROR: tools/perftest/ is empty. Run: git submodule update --init tools/perftest"; exit 1; } && \
    cd /tmp/perftest && \
    ./autogen.sh && \
    ./configure --prefix=/usr --enable-cudart && \
    make -j$(nproc) && \
    make install DESTDIR=/install


# ============================================================================
# Final Stage: Compact runtime image
# ============================================================================
FROM ${RUNTIME_IMAGE}

# Root required: RDMA perftest (ib_write_bw, ib_read_bw) and GPU bandwidth tools
# need direct access to InfiniBand/RoCE devices and CUDA runtime.
USER root

WORKDIR /root

# Install runtime utilities
RUN dnf install -y \
    wget procps-ng jq bc iputils ethtool net-tools \
    numactl kmod systemd-udev libpcap python3 hostname \
    iperf3 tcpdump pciutils \
    && dnf clean all

# Install RDMA libraries (matches what perftest was compiled against)
RUN dnf install -y libibverbs libibverbs-utils libibumad librdmacm infiniband-diags && dnf clean all

# Copy perftest binaries from builder
COPY --from=builder /install/usr/bin/* /usr/local/bin/

# Copy libcudart from builder — the only CUDA library perftest needs at runtime (~756K).
# The GPU driver library (libcuda.so.1) is mounted by the NVIDIA Container Toolkit.
COPY --from=builder /usr/local/cuda/lib64/libcudart.so.* /usr/local/lib/
RUN echo "/usr/local/lib" > /etc/ld.so.conf.d/cuda.conf && ldconfig

# Create results directory
RUN mkdir -p /results

CMD ["/bin/bash"]
